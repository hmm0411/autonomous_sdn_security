{
    "id": null,
    "title": "SDN RL Observability Dashboard",
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "5s",
    "panels": [
        {
            "type": "timeseries",
            "title": "Reward Comparison",
            "targets": [
                {
                    "expr": "rl_reward{agent=\"dqn\"}",
                    "legendFormat": "DQN"
                },
                {
                    "expr": "rl_reward{agent=\"ppo\"}",
                    "legendFormat": "PPO"
                },
                {
                    "expr": "rl_reward{agent=\"baseline\"}",
                    "legendFormat": "Baseline"
                }
            ],
            "gridPos": {
                "x": 0,
                "y": 0,
                "w": 12,
                "h": 8
            }
        },
        {
            "type": "timeseries",
            "title": "Latency Comparison",
