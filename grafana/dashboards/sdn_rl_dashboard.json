{
    "title": "SDN RL Observability Dashboard (Full)",
    "refresh": "5s",
    "panels": [
        {
            "type": "timeseries",
            "title": "Reward Performance",
            "targets": [
                {
                    "expr": "episode_reward{agent='dqn'}",
                    "legendFormat": "DQN Reward"
                },
                {
                    "expr": "episode_reward{agent='ppo'}",
                    "legendFormat": "PPO Reward"
                }
            ],
            "gridPos": {
                "x": 0,
                "y": 0,
                "w": 12,
                "h": 8
            }
        },
        {
            "type": "timeseries",
            "title": "Network Throughput (Packet Rate)",
            "targets": [
                {
                    "expr": "sdn_packet_rate",
                    "legendFormat": "Packet Rate (pps)"
                }
            ],
            "gridPos": {
                "x": 12,
                "y": 0,
                "w": 12,
                "h": 8
            }
        },
        {
            "type": "timeseries",
            "title": "System Latency & Flow Count",
            "targets": [
                {
                    "expr": "sdn_latency_ms",
                    "legendFormat": "Latency (ms)"
                },
                {
                    "expr": "sdn_flow_count",
                    "legendFormat": "Active Flows"
                }
            ],
            "gridPos": {
                "x": 0,
                "y": 8,
                "w": 12,
                "h": 8
            }
        },
        {
            "type": "timeseries",
            "title": "Training Loss History",
            "targets": [
                {
                    "expr": "training_loss{agent='dqn'}",
                    "legendFormat": "DQN Loss"
                },
                {
                    "expr": "training_loss{agent='ppo'}",
                    "legendFormat": "PPO Loss"
                }
            ],
            "gridPos": {
                "x": 12,
                "y": 8,
                "w": 12,
                "h": 8
            }
        },
        {
            "type": "gauge",
            "title": "Controller CPU Load",
            "targets": [
                {
                    "expr": "sdn_controller_cpu",
                    "legendFormat": "CPU %"
                }
            ],
            "gridPos": {
                "x": 0,
                "y": 16,
                "w": 8,
                "h": 6
            }
        },
        {
            "type": "stat",
            "title": "Model Status",
            "targets": [
                {
                    "expr": "up{job='rl-agent-dqn'} == 1",
                    "legendFormat": "DQN Agent Ready"
                },
                {
                    "expr": "up{job='rl-agent-ppo'} == 1",
                    "legendFormat": "PPO Agent Ready"
                }
            ],
            "gridPos": {
                "x": 8,
                "y": 16,
                "w": 8,
                "h": 6
            }
        }
    ]
}