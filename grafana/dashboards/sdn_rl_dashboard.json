{
    "title": "SDN RL Observability Dashboard",
    "uid": "sdn-rl-observability",
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 2,
    "refresh": "5s",
    "tags": [
        "SDN",
        "RL",
        "MLOps",
        "Prometheus"
    ],
    "panels": [
        {
            "id": 1,
            "type": "timeseries",
            "title": "Runtime Reward - Production vs Staging",
            "datasource": "Prometheus",
            "targets": [
                {
                    "expr": "rl_reward{stage=\"production\"}",
                    "legendFormat": "{{model_type}} Production",
                    "refId": "A"
                },
                {
                    "expr": "rl_reward{stage=\"staging\"}",
                    "legendFormat": "{{model_type}} Staging",
                    "refId": "B"
                }
            ],
            "gridPos": {
                "x": 0,
                "y": 0,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            }
        },
        {
            "id": 2,
            "type": "timeseries",
            "title": "Runtime Latency",
            "datasource": "Prometheus",
            "targets": [
                {
                    "expr": "rl_latency",
                    "legendFormat": "{{model_type}} latency",
                    "refId": "A"
                }
            ],
            "gridPos": {
                "x": 12,
                "y": 0,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "ms"
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            }
        },
        {
            "id": 3,
            "type": "timeseries",
            "title": "Flow Count",
            "datasource": "Prometheus",
            "targets": [
                {
                    "expr": "rl_flow_count",
                    "legendFormat": "{{model_type}} flow count",
                    "refId": "A"
                }
            ],
            "gridPos": {
                "x": 0,
                "y": 8,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            }
        },
        {
            "id": 4,
            "type": "timeseries",
            "title": "RL Action History",
            "datasource": "Prometheus",
            "targets": [
                {
                    "expr": "rl_action",
                    "legendFormat": "{{model_type}} action",
                    "refId": "A"
                }
            ],
            "gridPos": {
                "x": 12,
                "y": 8,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "min": -0.5,
                    "max": 4.5,
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "0": {
                                    "text": "0: No Action"
                                },
                                "1": {
                                    "text": "1: Block"
                                },
                                "2": {
                                    "text": "2: Limit Bandwidth"
                                },
                                "3": {
                                    "text": "3: Redirect"
                                },
                                "4": {
                                    "text": "4: Isolate"
                                }
                            }
                        }
                    ]
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            }
        },
        {
            "id": 5,
            "type": "timeseries",
            "title": "Packet Loss",
            "datasource": "Prometheus",
            "targets": [
                {
                    "expr": "rl_packet_loss",
                    "legendFormat": "{{model_type}} packet loss",
                    "refId": "A"
                }
            ],
            "gridPos": {
                "x": 0,
                "y": 16,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percentunit",
                    "min": 0
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            }
        },
        {
            "id": 6,
            "type": "timeseries",
            "title": "Controller CPU",
            "datasource": "Prometheus",
            "targets": [
                {
                    "expr": "rl_controller_cpu",
                    "legendFormat": "{{model_type}} controller cpu",
                    "refId": "A"
                }
            ],
            "gridPos": {
                "x": 12,
                "y": 16,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            }
        },
        {
            "id": 7,
            "type": "timeseries",
            "title": "Serving Requests",
            "datasource": "Prometheus",
            "targets": [
                {
                    "expr": "rate(serving_requests_total[1m])",
                    "legendFormat": "{{model}} request/s",
                    "refId": "A"
                }
            ],
            "gridPos": {
                "x": 0,
                "y": 24,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps"
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            }
        },
        {
            "id": 8,
            "type": "timeseries",
            "title": "Serving Latency",
            "datasource": "Prometheus",
            "targets": [
                {
                    "expr": "rate(serving_latency_seconds_sum[1m]) / rate(serving_latency_seconds_count[1m])",
                    "legendFormat": "{{model}} avg latency",
                    "refId": "A"
                }
            ],
            "gridPos": {
                "x": 12,
                "y": 24,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s"
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            }
        },
        {
            "id": 9,
            "type": "stat",
            "title": "Service Status",
            "datasource": "Prometheus",
            "targets": [
                {
                    "expr": "up{job=\"rl-serving-dqn\"}",
                    "legendFormat": "DQN Serving",
                    "refId": "A"
                },
                {
                    "expr": "up{job=\"rl-serving-ppo\"}",
                    "legendFormat": "PPO Serving",
                    "refId": "B"
                },
                {
                    "expr": "up{job=\"control_loop\"}",
                    "legendFormat": "Control Loop",
                    "refId": "C"
                },
                {
                    "expr": "up{job=\"sdn-defense-agent\"}",
                    "legendFormat": "Defense Agent",
                    "refId": "D"
                },
                {
                    "expr": "up{job=\"auto-trigger\"}",
                    "legendFormat": "Auto Trigger",
                    "refId": "E"
                }
            ],
            "gridPos": {
                "x": 0,
                "y": 32,
                "w": 24,
                "h": 6
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "0": {
                                    "text": "DOWN"
                                },
                                "1": {
                                    "text": "UP"
                                }
                            }
                        }
                    ],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "green",
                                "value": 1
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "values": false,
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": ""
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "value",
                "graphMode": "none",
                "justifyMode": "auto"
            }
        },
        {
            "id": 10,
            "type": "stat",
            "title": "System Security Status",
            "datasource": "Prometheus",
            "targets": [
                {
                    "expr": "threat_level",
                    "legendFormat": "Security Status",
                    "refId": "A"
                }
            ],
            "gridPos": {
                "x": 0,
                "y": 40,
                "w": 8,
                "h": 7
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "none",
                    "min": 0,
                    "max": 100,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "orange",
                                "value": 31
                            },
                            {
                                "color": "red",
                                "value": 71
                            }
                        ]
                    },
                    "mappings": [
                        {
                            "type": "range",
                            "options": {
                                "from": 0,
                                "to": 30,
                                "result": {
                                    "text": "SAFE",
                                    "color": "green"
                                }
                            }
                        },
                        {
                            "type": "range",
                            "options": {
                                "from": 31,
                                "to": 70,
                                "result": {
                                    "text": "WARNING",
                                    "color": "orange"
                                }
                            }
                        },
                        {
                            "type": "range",
                            "options": {
                                "from": 71,
                                "to": 100,
                                "result": {
                                    "text": "CRITICAL",
                                    "color": "red"
                                }
                            }
                        }
                    ]
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "values": false,
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": ""
                },
                "orientation": "auto",
                "textMode": "value_and_name",
                "colorMode": "background",
                "graphMode": "none",
                "justifyMode": "center"
            }
        },
        {
            "id": 11,
            "type": "gauge",
            "title": "Threat Level",
            "datasource": "Prometheus",
            "targets": [
                {
                    "expr": "threat_level",
                    "legendFormat": "Threat Level",
                    "refId": "A"
                }
            ],
            "gridPos": {
                "x": 8,
                "y": 40,
                "w": 8,
                "h": 7
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "orange",
                                "value": 31
                            },
                            {
                                "color": "red",
                                "value": 71
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "values": false,
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": ""
                },
                "orientation": "auto",
                "showThresholdLabels": true,
                "showThresholdMarkers": true
            }
        },
        {
            "id": 12,
            "type": "stat",
            "title": "Defense Action Status",
            "datasource": "Prometheus",
            "targets": [
                {
                    "expr": "defense_rl_action",
                    "legendFormat": "Defense Action",
                    "refId": "A"
                }
            ],
            "gridPos": {
                "x": 16,
                "y": 40,
                "w": 8,
                "h": 7
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "none",
                    "min": 0,
                    "max": 4,
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "0": {
                                    "text": "NO ACTION",
                                    "color": "green"
                                },
                                "1": {
                                    "text": "BLOCK",
                                    "color": "red"
                                },
                                "2": {
                                    "text": "RATE LIMIT",
                                    "color": "orange"
                                },
                                "3": {
                                    "text": "REDIRECT",
                                    "color": "blue"
                                },
                                "4": {
                                    "text": "ISOLATE",
                                    "color": "purple"
                                }
                            }
                        }
                    ],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "orange",
                                "value": 1
                            },
                            {
                                "color": "red",
                                "value": 4
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "values": false,
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": ""
                },
                "orientation": "auto",
                "textMode": "value_and_name",
                "colorMode": "background",
                "graphMode": "none",
                "justifyMode": "center"
            }
        },
        {
            "id": 13,
            "type": "timeseries",
            "title": "Defense Confidence",
            "datasource": "Prometheus",
            "targets": [
                {
                    "expr": "defense_confidence",
                    "legendFormat": "Confidence",
                    "refId": "A"
                }
            ],
            "gridPos": {
                "x": 0,
                "y": 47,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            }
        },
        {
            "id": 14,
            "type": "timeseries",
            "title": "Defense Flow Count",
            "datasource": "Prometheus",
            "targets": [
                {
                    "expr": "defense_flow_count",
                    "legendFormat": "Flow Count",
                    "refId": "A"
                }
            ],
            "gridPos": {
                "x": 12,
                "y": 47,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "min": 0
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            }
        }
    ],
    "time": {
        "from": "now-15m",
        "to": "now"
    },
    "templating": {
        "list": []
    },
    "annotations": {
        "list": [
            {
                "builtIn": 1,
                "datasource": {
                    "type": "grafana",
                    "uid": "-- Grafana --"
                },
                "enable": true,
                "hide": true,
                "iconColor": "rgba(0, 211, 255, 1)",
                "name": "Annotations & Alerts",
                "type": "dashboard"
            }
        ]
    }
}